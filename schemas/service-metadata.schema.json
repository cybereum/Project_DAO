{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cybereum.io/schemas/service-metadata/v1",
  "title": "Project_DAO Service Metadata",
  "description": "JSON schema for service listing metadata stored at the metadataURI registered via listService(). Defines the interface, SLA, and auth requirements for an agent-to-agent service.",
  "type": "object",
  "required": ["service", "interface"],
  "properties": {
    "service": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human- and machine-readable service name.",
          "minLength": 1,
          "maxLength": 256
        },
        "description": {
          "type": "string",
          "description": "Plain-text description of what this service does. Should be parseable by AI agents.",
          "maxLength": 2048
        },
        "version": {
          "type": "string",
          "description": "Semantic version of the service API.",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "examples": ["1.0.0", "2.1.3"]
        },
        "category": {
          "type": "string",
          "description": "Service category matching the on-chain serviceType.",
          "examples": ["price-feed", "translation", "code-audit", "data-analysis"]
        }
      }
    },
    "interface": {
      "type": "object",
      "description": "Machine-readable API specification for invoking this service.",
      "required": ["request", "response"],
      "properties": {
        "request": {
          "type": "object",
          "properties": {
            "method": {
              "type": "string",
              "enum": ["GET", "POST"],
              "default": "POST"
            },
            "path": {
              "type": "string",
              "description": "API path relative to the agent's endpoint URL.",
              "examples": ["/v1/price", "/v1/translate"]
            },
            "contentType": {
              "type": "string",
              "default": "application/json"
            },
            "params": {
              "type": "object",
              "description": "Request parameter definitions. Keys are parameter names.",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["string", "integer", "number", "boolean", "object", "array"] },
                  "required": { "type": "boolean", "default": false },
                  "description": { "type": "string" },
                  "default": {},
                  "example": {},
                  "enum": { "type": "array" }
                }
              }
            }
          }
        },
        "response": {
          "type": "object",
          "properties": {
            "contentType": {
              "type": "string",
              "default": "application/json"
            },
            "schema": {
              "type": "object",
              "description": "Response field definitions. Keys are field names.",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "type": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "sla": {
      "type": "object",
      "description": "Service level agreement parameters.",
      "properties": {
        "maxResponseTimeMs": {
          "type": "integer",
          "description": "Maximum expected response time in milliseconds.",
          "minimum": 100
        },
        "uptimeTarget": {
          "type": "number",
          "description": "Target uptime as a decimal (e.g., 0.995 = 99.5%).",
          "minimum": 0,
          "maximum": 1
        },
        "rateLimitPerMinute": {
          "type": "integer",
          "description": "Maximum requests per minute.",
          "minimum": 1
        }
      }
    },
    "auth": {
      "type": "object",
      "description": "Authentication requirements for invoking this service off-chain.",
      "properties": {
        "method": {
          "type": "string",
          "enum": ["none", "eip191-signature", "api-key"],
          "description": "Authentication method required."
        },
        "details": {
          "type": "string",
          "description": "Human-readable auth instructions."
        }
      }
    }
  },
  "additionalProperties": true
}
