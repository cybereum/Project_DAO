# Required — RPC endpoint (HTTP or WebSocket)
RPC_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Required — deployed Project_DAO contract address
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional — POST JSON event payloads to this URL (Slack, PagerDuty, etc.)
WEBHOOK_URL=

# Optional — ETH threshold for large-transfer alerts (default: 1.0)
ALERT_THRESHOLD_ETH=1.0
