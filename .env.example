# ─── Contract Deployment (Hardhat) ─────────────────────────────────────────
# Private key of the deployer account (hex, with 0x prefix)
DEPLOYER_PRIVATE_KEY=0x...

# Treasury address for protocol fees (required for non-local deployments)
CYBEREUM_TREASURY=0x...

# Fee configuration (optional — defaults: 5 bps, 1e12 wei asset fee)
# FEE_BPS=5
# ASSET_FEE_WEI=1000000000000

# ─── Network RPC URLs ─────────────────────────────────────────────────────
# Only needed for deploying to non-local networks
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
