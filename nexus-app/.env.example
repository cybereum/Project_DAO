# ─── Required ───────────────────────────────────────────────────────────
# Deployed Project_DAO contract address (e.g. 0x1234...abcd)
# Get this from the deployment script output
VITE_PROJECT_DAO_ADDRESS=

# ─── Owner Dashboard (optional) ────────────────────────────────────────
# Passcode to unlock the private owner dashboard at /owner
VITE_OWNER_DASHBOARD_PASSCODE=
# Restrict owner dashboard to this wallet address (optional, empty = any wallet)
VITE_OWNER_WALLET_ADDRESS=

# ─── AI Analysis Server (optional) ─────────────────────────────────────
# URL of the NexusAI analysis server (defaults to http://localhost:3737)
VITE_NEXUS_AI_URL=

# ─── Analytics (optional) ──────────────────────────────────────────────
# Google Analytics 4 measurement ID
VITE_GA_MEASUREMENT_ID=
# Plausible Analytics domain
VITE_PLAUSIBLE_DOMAIN=

# ─── Lead Capture (optional) ───────────────────────────────────────────
# Webhook URL for lead capture form submissions (e.g. Zapier, Make, etc.)
VITE_LEAD_WEBHOOK=
