# ─── Required ─────────────────────────────────────────────────────────────────
# Deployed Project_DAO contract address (0x + 40 hex characters)
VITE_PROJECT_DAO_ADDRESS=

# ─── Owner Dashboard (optional) ──────────────────────────────────────────────
# Client-side passcode for owner dashboard access (NOT secure — use for dev only)
VITE_OWNER_DASHBOARD_PASSCODE=
# Owner wallet address for dashboard filtering
VITE_OWNER_WALLET_ADDRESS=

# ─── AI Analysis Server (optional) ───────────────────────────────────────────
# URL for the NexusAI analysis server. Defaults to http://localhost:3737.
# IMPORTANT: Use HTTPS in production to protect wallet addresses and payment hashes.
VITE_NEXUS_AI_URL=

# ─── Analytics (optional) ────────────────────────────────────────────────────
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
# Plausible Analytics domain (e.g. cybereum.io)
VITE_PLAUSIBLE_DOMAIN=

# ─── Lead Capture (optional) ─────────────────────────────────────────────────
# Webhook URL for email capture form submissions
VITE_LEAD_WEBHOOK=
